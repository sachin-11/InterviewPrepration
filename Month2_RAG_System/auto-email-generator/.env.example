# Required
GROQ_API_KEY=
EMAIL_USER=
EMAIL_PASS=

# Optional LLM model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=

# Required when NODE_ENV=production
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: protect APIs with header x-api-key (automation / scripts)
# INTERNAL_API_KEY=

# Login: if set, users must sign in at /login (needs SESSION_SECRET too)
# APP_PASSWORD=
# SESSION_SECRET=use-at-least-32-characters-long-secret-key

# Scheduled sends: call POST /api/cron/process-scheduled with Authorization: Bearer <secret>
# (e.g. Vercel Cron, GitHub Actions, or system cron hitting your deployed URL)
# CRON_SECRET=

# Custom SMTP (if SMTP_HOST set, host/port/secure/auth used; else Gmail + EMAIL_*)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Rate limit (per IP, in-process — use Redis for multi-instance)
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=3600000
